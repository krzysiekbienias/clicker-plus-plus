{
    // Wyłącz AI podpowiedzi w kodzie (Cursor Tab / szary ghost text)
    "editor.inlineSuggest.enabled": false,
    "github.copilot.enable": {
        "*": false
    },

    // Zostaw podpowiedzi składni języka (clangd / IntelliSense)
    "editor.quickSuggestions": {
        "other": "on",
        "comments": "off",
        "strings": "off"
    },
    "editor.suggestOnTriggerCharacters": true,
    "editor.parameterHints.enabled": true,
    "editor.wordBasedSuggestions": "off",
    "editor.suggest.showWords": false,

    "workbench.colorTheme": "Monokai",
    "testMate.cpp.test.executables": "${workspaceFolder}/build/test_environment",
    "testMate.cpp.test.advancedExecutables": [
        {
            "pattern": "build/test_environment",
            "cwd": "${workspaceFolder}",
            "runTask": {
                "before": ["build (Cursor)"]
            }
        }
    ],
    "testMate.cpp.debug.configTemplate": {
        "type": "lldb",
        "request": "launch",
        "program": "${exec}",
        "args": "${argsArray}",
        "cwd": "${cwd}",
        "preLaunchTask": "build (Cursor)"
    },
    "cmake.sourceDirectory": "${workspaceFolder}"
}
